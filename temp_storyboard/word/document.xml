8" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Audience</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcBorders><w:top w:val="single" w:color="D9D7CF" w:sz="1"/><w:left w:val="single" w:color="D9D7CF" w:sz="1"/><w:bottom w:val="single" w:color="D9D7CF" w:sz="1"/><w:right w:val="single" w:color="D9D7CF" w:sz="1"/></w:tcBorders><w:shd w:fill="FBFBF8" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Primary Goal</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcBorders><w:top w:val="single" w:color="D9D7CF" w:sz="1"/><w:left w:val="single" w:color="D9D7CF" w:sz="1"/><w:bottom w:val="single" w:color="D9D7CF" w:sz="1"/><w:right w:val="single" w:color="D9D7CF" w:sz="1"/></w:tcBorders><w:shd w:fill="FBFBF8" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Document Type</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcBorders><w:top w:val="single" w:color="D9D7CF" w:sz="1"/><w:left w:val="single" w:color="D9D7CF" w:sz="1"/><w:bottom w:val="single" w:color="D9D7CF" w:sz="1"/><w:right w:val="single" w:color="D9D7CF" w:sz="1"/></w:tcBorders><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:t xml:space="preserve">Plumb — Hiring Funnel Automation</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcBorders><w:top w:val="single" w:color="D9D7CF" w:sz="1"/><w:left w:val="single" w:color="D9D7CF" w:sz="1"/><w:bottom w:val="single" w:color="D9D7CF" w:sz="1"/><w:right w:val="single" w:color="D9D7CF" w:sz="1"/></w:tcBorders><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:t xml:space="preserve">Recruiters &amp; Hiring Teams</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcBorders><w:top w:val="single" w:color="D9D7CF" w:sz="1"/><w:left w:val="single" w:color="D9D7CF" w:sz="1"/><w:bottom w:val="single" w:color="D9D7CF" w:sz="1"/><w:right w:val="single" w:color="D9D7CF" w:sz="1"/></w:tcBorders><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:t xml:space="preserve">Drive signups for free trial</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcBorders><w:top w:val="single" w:color="D9D7CF" w:sz="1"/><w:left w:val="single" w:color="D9D7CF" w:sz="1"/><w:bottom w:val="single" w:color="D9D7CF" w:sz="1"/><w:right w:val="single" w:color="D9D7CF" w:sz="1"/></w:tcBorders><w:tcMar><w:top w:type="dxa" w:w="80"/><w:left w:type="dxa" w:w="120"/><w:bottom w:type="dxa" w:w="80"/><w:right w:type="dxa" w:w="120"/></w:tcMar></w:tcPr><w:p><w:r><w:t xml:space="preserve">Developer Storyboard</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Product Brief</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">Plumb is a hiring automation platform that orchestrates the entire recruiting funnel—from sourcing through shortlisting to final decision. The core value: recruiters spend less time on manual screening and more time making great hires.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key differentiator: Live AI-powered candidate scoring and filtering. Candidates enter the pipeline, get automatically scored and ranked, and top performers bubble to the surface—all in real time.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Storyboard: 6-Scene Narrative Arc</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Scene 01: Hero: Value Proposition Lands</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">User arrives on the page and is immediately greeted with an animated headline reveal. The core message is clear and benefit-driven: &apos;Less hiring. More hires.&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key Elements:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Headline: &apos;Plumb — Less hiring. More hires.&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Subheading: &apos;Plumb runs the hiring funnel. You make the call.&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Visual: Animated plumb bob logo + text stagger animation</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• CTAs: Primary &apos;Start free&apos; + Secondary &apos;Request demo&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="455F51"/></w:rPr><w:t xml:space="preserve">User Action: Lands on page, reads headline, evaluates primary CTA</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">Purpose: Immediate impact. Establish problem/solution in one glance. Hook emotionally with the animation.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Scene 02: Pipeline Visualization: The Process</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">User scrolls and encounters the main product animation. Resume cards flow through a hiring pipeline with stages: Sourcing → Shortlisting → Briefing → Ready. This visualizes the workflow and positions Plumb as the orchestrator.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key Elements:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Layout: Horizontal pipeline with 4 stages</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Animation: Resume cards slide left-to-right, re-scored at each stage</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Status Label: Cycles through &apos;Sourcing,&apos; &apos;Shortlisting,&apos; &apos;Briefing,&apos; &apos;Ready&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Color/Score: Cards show rejection (red), mid-tier (yellow), promoted (green)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Interaction: Cards loop endlessly, re-score on each cycle</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="455F51"/></w:rPr><w:t xml:space="preserve">User Action: Watches the animation, understands the funnel stages</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">Purpose: Build comprehension of the hiring process. Establish that Plumb automates multiple stages, not just one.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Scene 03: Candidate Engine: Live Demo</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">The &apos;magic moment.&apos; User sees a live, real-time candidate stream. New candidates appear, get scored (42–98), and are instantly filtered or promoted to a shortlist. Counters update in real time. This is the interactive proof point.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key Elements:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Left Pane (Inbound Stream): Candidates flow in with avatar, name, role, score</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Scoring Logic: Score &lt;70 = filtered (red), 70–84 = neutral (yellow), ≥85 = promoted (green)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Right Pane (Shortlist): Top 5 candidates by score, ranked 01–05, with initials/colors</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Live Counters: &apos;327 scanned&apos; | &apos;203 filtered&apos; | &apos;Top score: 91&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Cadence: New candidate every 1.2 seconds, scoring decision within 600–1100ms</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="455F51"/></w:rPr><w:t xml:space="preserve">User Action: Watches candidates flow, observes automation, sees results update live</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">Purpose: Demonstrate the product&apos;s core capability in an engaging, interactive way. Create a &apos;wow&apos; moment that&apos;s more compelling than static text.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Scene 04: Results &amp; Metrics: Proof of Value</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">User sees quantifiable benefits highlighted. Key stats (10x faster, 80% less manual work, etc.) are presented alongside possible testimonials or case-study callouts. This builds confidence in the product&apos;s efficacy.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key Elements:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Format: 2x2 or 1x4 metric card grid</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Sample Stats: &apos;10x faster screening&apos; | &apos;80% less manual work&apos; | &apos;98% accuracy&apos; | &apos;48h to interview&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Visual Treatment: Large numbers + smaller label copy, icon or color accent per stat</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Optional: Customer logo bar or one short testimonial quote</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="455F51"/></w:rPr><w:t xml:space="preserve">User Action: Scans metrics, builds belief in ROI, considers cost/benefit</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">Purpose: Provide quantitative evidence that Plumb delivers real results. Answer the implicit question: &apos;Will this actually save me time?&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Scene 05: Features Deep-Dive: How It Works</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">User learns about the product&apos;s core capabilities in more detail. Sections on AI parsing, role-to-candidate matching, automated outreach, shortlisting logic, and analytics. Each may include small diagrams, icons, or animations.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key Elements:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Typical Features: Resume parsing | Role matching | Scoring | Shortlisting | Outreach | Analytics</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Format: Section per feature, icon + headline + 2–3 lines of copy</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Layout: Could be 2-column grid or full-width cards, repeating</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Optional Micro-interaction: Hover reveals more detail, or small explainer animation</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="455F51"/></w:rPr><w:t xml:space="preserve">User Action: Reads feature descriptions, understands technical capability</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">Purpose: Build technical credibility. Answer &apos;How does this actually work?&apos; Reinforce differentiation.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t xml:space="preserve">Scene 06: Conversion: Final CTA &amp; Trust Signals</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">Footer section with a strong call-to-action for signup or demo request. Include a trust signal (no credit card required, or customer logos, or a guarantee). This is the final moment to convert interest into action.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Key Elements:</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Headline: &apos;Start screening smarter today&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Primary CTA: &apos;Start free&apos; button (large, dark, prominent)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Secondary CTA: &apos;Request demo&apos; link</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Trust Signal: &apos;No credit card required&apos; or customer logos or &apos;14-day free trial&apos;</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60"/><w:ind w:left="720"/></w:pPr><w:r><w:t xml:space="preserve">• Footer: Links to product, company, legal pages</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/><w:color w:val="455F51"/></w:rPr><w:t xml:space="preserve">User Action: Decides to sign up, request demo, or leave impressed</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">Purpose: Remove final friction. Convert convinced visitor into a trial user, lead, or sales conversation.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Developer Implementation Notes</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">1. Real Data vs. Mocks</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">Scene 3 (Candidate Engine): Currently uses randomized mock data (FIRST_NAMES, ROLES, etc.). Will this eventually pull from a real API, or stay as a demo widget? Answer needed before build: Are we building a static demo, or a connect-to-backend feature?</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">2. Animation Performance</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">The landing page uses requestAnimationFrame for smooth animations. Key timings: Hero text staggered reveals (0.6s–1.9s delays); Pipeline cards continuous 60fps loop; Candidate engine new card every 1.2s with scoring decision within 600–1100ms. All animations use CSS transforms + JS RAF for GPU acceleration.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">3. Responsive Design</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">Current implementation uses @media (max-width: 960px) breakpoints. The hero grid collapses from 2-column to 1-column. Ensure the candidate engine demo (Scene 3) is readable on mobile or consider hiding/simplifying on smaller screens.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">4. Design Language</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">Color Palette: Forest green accent (#455F51), cream bg (#E3DED1), warm paper tones for resume cards. Typography: Inter for body, JetBrains Mono for labels. Keep hierarchy consistent with existing design system.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">5. Accessibility</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120"/></w:pPr><w:r><w:t xml:space="preserve">Ensure all animated text has sufficient contrast. The animated pipeline and candidate engine should have fallback text for screen readers. Consider reducing motion for users with prefers-reduced-motion enabled.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">6. Testing Checklist</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="240"/></w:pPr><w:r><w:t xml:space="preserve">✓ Hero text animations trigger on page load  ✓ Pipeline cards loop smoothly without jank  ✓ Candidate engine scores update in real time  ✓ CTAs are clickable and direct to signup/contact  ✓ Mobile: all sections reflow correctly, animations still smooth  ✓ Scroll performance: no layout thrashing, FPS stable  ✓ Cross-browser: Chrome, Safari, Firefox, Edge</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="120" w:before="240"/><w:jc w:val="center"/></w:pPr><w:r><w:t xml:space="preserve">Plumb Landing Page Storyboard — For Development Team</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:t xml:space="preserve">Status: Ready for Build</w:t></w:r></w:p><w:sectPr><w:pgSz w:w="12240" w:h="15840" w:orient="portrait"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:pgNumType/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>